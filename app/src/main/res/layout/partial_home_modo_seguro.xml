<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutModoSeguroPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/safeTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="#F4F7FA"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODO EXPLORACIÓN LIBRE"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#7F8C8D" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Práctica Autónoma"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A202C" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#FF7A00"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❓"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AYUDA"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/safeTopBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="90dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#E8F0FE"
                app:strokeColor="#1A73E8"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="#1A73E8"
                        app:strokeWidth="0dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🛡️"
                            android:textSize="20sp"/>
                    </com.google.android.material.card.MaterialCardView>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Modo Seguro Activo"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A73E8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="No se enviará nada real. ¡Practica sin miedo!"
                            android:textSize="13sp"
                            android:textColor="#5F6368" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="APLICACIONES DISPONIBLES"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A73E8" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSafeWhatsapp"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#2ECC71" app:strokeWidth="0dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="💬" android:textSize="22sp"/></com.google.android.material.card.MaterialCardView><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:background="#E8F8F5" android:text="● SIMULACIÓN" android:textSize="10sp" android:textStyle="bold" android:textColor="#2ECC71"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Explorar WhatsApp" android:textSize="16sp" android:textStyle="bold" android:textColor="#2C3E50"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Explora chats y menús sin riesgo de enviar nada." android:textSize="12sp" android:textColor="#7F8C8D"/></LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSafeBizum"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#1A73E8" app:strokeWidth="0dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="💶" android:textSize="22sp"/></com.google.android.material.card.MaterialCardView><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:background="#E8F0FE" android:text="● SIMULACIÓN" android:textSize="10sp" android:textStyle="bold" android:textColor="#1A73E8"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Explorar Bizum" android:textSize="16sp" android:textStyle="bold" android:textColor="#2C3E50"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Simula envíos de dinero sin dinero real." android:textSize="12sp" android:textColor="#7F8C8D"/></LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSafeSalud"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#E74C3C" app:strokeWidth="0dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🏥" android:textSize="22sp"/></com.google.android.material.card.MaterialCardView><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:background="#FDEDEC" android:text="● SIMULACIÓN" android:textSize="10sp" android:textStyle="bold" android:textColor="#E74C3C"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Explorar Salud" android:textSize="16sp" android:textStyle="bold" android:textColor="#2C3E50"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Practica cómo pedir una cita médica ficticia." android:textSize="12sp" android:textColor="#7F8C8D"/></LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSafeCorreo"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#9B59B6" app:strokeWidth="0dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="✉️" android:textSize="22sp"/></com.google.android.material.card.MaterialCardView><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:background="#F5EEF8" android:text="● SIMULACIÓN" android:textSize="10sp" android:textStyle="bold" android:textColor="#9B59B6"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Explorar Correo" android:textSize="16sp" android:textStyle="bold" android:textColor="#2C3E50"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Redacta y organiza correos simulados." android:textSize="12sp" android:textColor="#7F8C8D"/></LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSafeMaps"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#F1C40F" app:strokeWidth="0dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🗺️" android:textSize="22sp"/></com.google.android.material.card.MaterialCardView><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:background="#FEF9E7" android:text="● SIMULACIÓN" android:textSize="10sp" android:textStyle="bold" android:textColor="#F1C40F"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Explorar Maps" android:textSize="16sp" android:textStyle="bold" android:textColor="#2C3E50"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Busca calles y rutas seguras de autobuses." android:textSize="12sp" android:textColor="#7F8C8D"/></LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="#1A73E8"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="💡"
                android:textSize="26sp"/>
        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pista / Ayuda"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="#FFFFFF"
            android:textColor="#1A73E8"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>