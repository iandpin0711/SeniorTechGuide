<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutProgresoPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A73E8"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buenos días,"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvProgresoNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Rosa García"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#FBC02D"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView
                android:id="@+id/tvProgresoInicialAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="R"
                android:textColor="#2C3E50"
                android:textSize="20sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="90dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tu Progreso"
                        android:textColor="#1A202C"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <FrameLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="16dp">
                            <ProgressBar
                                android:id="@+id/pbProgresoCircular"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:indeterminate="false"
                                android:progress="0"
                                android:max="100"
                                android:rotation="-90"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:progressDrawable="@android:drawable/progress_horizontal" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_gravity="center"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tvProgresoPorcentaje"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#1A73E8"
                                    android:textSize="18sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="completado"
                                    android:textColor="#7F8C8D"
                                    android:textSize="10sp"/>
                            </LinearLayout>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvProgresoContador"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 de 0 misiones\nsuperadas"
                                android:textColor="#1A202C"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:lineSpacingExtra="2dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="¡Sigue así, lo estás haciendo genial!"
                                android:textColor="#7F8C8D"
                                android:textSize="13sp"/>

                            <ProgressBar
                                android:id="@+id/pbProgresoHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:layout_marginTop="12dp"
                                android:progress="0"
                                android:max="100"
                                style="?android:attr/progressBarStyleHorizontal"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgresoItemWhatsapp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F2F4F5"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/tvIconProgresoWhatsapp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚪"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:id="@+id/tvTextProgresoWhatsapp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Misión WhatsApp: Enviar un mensaje"
                            android:textColor="#7F8C8D"
                            android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/tvCheckProgresoWhatsapp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textColor="#1A73E8"
                            android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgresoItemBizum"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F2F4F5"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/tvIconProgresoBizum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚪"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:id="@+id/tvTextProgresoBizum"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Misión Bizum: Enviar dinero seguro"
                            android:textColor="#7F8C8D"
                            android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/tvCheckProgresoBizum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textColor="#1A73E8"
                            android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgresoItemMaps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F2F4F5"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/tvIconProgresoMaps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚪"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:id="@+id/tvTextProgresoMaps"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Misión Maps: Buscar una ruta"
                            android:textColor="#7F8C8D"
                            android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/tvCheckProgresoMaps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textColor="#1A73E8"
                            android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgresoItemCorreo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F2F4F5"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvIconProgresoCorreo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚪"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:id="@+id/tvTextProgresoCorreo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Misión Gmail: Revisar correos"
                            android:textColor="#7F8C8D"
                            android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/tvCheckProgresoCorreo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textColor="#1A73E8"
                            android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFF9F2"
                app:strokeColor="#FFB03A"
                app:strokeWidth="2dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="22sp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¡Toca repasar WhatsApp!"
                            android:textColor="#5C3E14"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#FFFDF9"
                        app:strokeWidth="0dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                app:cardCornerRadius="20dp"
                                app:cardBackgroundColor="#2ECC71"
                                app:strokeWidth="0dp"
                                android:layout_marginEnd="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="💬"
                                    android:textSize="18sp"/>
                            </com.google.android.material.card.MaterialCardView>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Última práctica"
                                    android:textColor="#7F8C8D"
                                    android:textSize="13sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hace 48 horas"
                                    android:textColor="#FF9F1C"
                                    android:textStyle="bold"
                                    android:textSize="15sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hace 48 horas que no envías un mensaje de prueba. Practica un minuto para no olvidarlo."
                        android:textColor="#5C3E14"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="3dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProgresoPracticarAhora"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="▶  Practicar ahora"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1A73E8"
                        app:cornerRadius="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#E8F8F5"
                app:strokeColor="#A3E4D7"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consejo del día"
                            android:textColor="#16A085"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Practicar 5 minutos cada día es mejor que estudiar 1 hora a la semana."
                        android:textColor="#16A085"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>