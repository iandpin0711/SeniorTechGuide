<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F3F0"> <LinearLayout
    android:id="@+id/layoutCabeceraGuia"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#162A45"
    android:orientation="vertical"
    android:padding="16dp"
    android:elevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/layoutPasosIndicador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_centerVertical="true">

            <View android:id="@+id/step1_bar" android:layout_width="30dp" android:layout_height="6dp" android:background="#2ECC71" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/step2_bar" android:layout_width="12dp" android:layout_height="6dp" android:background="#5C7593" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/step3_bar" android:layout_width="12dp" android:layout_height="6dp" android:background="#5C7593" android:layout_marginEnd="4dp"/>
            <View android:id="@+id/step4_bar" android:layout_width="12dp" android:layout_height="6dp" android:background="#5C7593" android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvPasoFraccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/4"
                android:textColor="#8AA1B9"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#2A405E"
            app:cardElevation="0dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🔊"
                android:textSize="16sp"/>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <TextView
        android:id="@+id/tvTextoGuiaInstruccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="PASO 1: Toca la barra blanca de búsqueda superior para elegir a dónde quieres ir."
        android:textColor="#FFFFFF"
        android:textSize="19sp"
        android:textStyle="bold"
        android:lineSpacingExtra="3dp" />
</LinearLayout>

    <LinearLayout
        android:id="@+id/layoutBannerSeguro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F9C514"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:elevation="6dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️  Entorno seguro de pruebas — Tu ubicación real no se rastreará"
            android:textColor="#2C3E50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutCabeceraGuia"
        android:layout_above="@id/layoutBannerSeguro">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F4F3F0">

            <View android:layout_width="180dp" android:layout_height="220dp" android:background="#D1E7DD" android:layout_marginTop="40dp" android:layout_marginLeft="-20dp"/>

            <View android:layout_width="match_parent" android:layout_height="35dp" android:background="#A2D2FF" android:layout_marginTop="320dp"/>

            <View android:layout_width="45dp" android:layout_height="match_parent" android:background="#FFFFFF" android:layout_marginLeft="140dp"/>
            <View android:layout_width="40dp" android:layout_height="match_parent" android:background="#FFFFFF" android:layout_alignParentRight="true" android:layout_marginRight="60dp"/>
            <View android:layout_width="match_parent" android:layout_height="45dp" android:background="#FFFFFF" android:layout_marginTop="180dp"/>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/viewPaso1Busqueda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardBarraBuscar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="26dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📍" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Buscar aquí (Ej: Hospital Central)" android:textColor="#7F8C8D" android:textSize="16sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/viewPaso2ComoLlegar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Hospital"
                android:background="#162A45"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="140dp"
                android:layout_marginLeft="110dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hospital General Universitario" android:textColor="#2C3E50" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Abierto 24 horas • Avenida de la Salud, 12" android:textColor="#7F8C8D" android:textSize="13sp" android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnComoLlegar"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardBackgroundColor="#1A73E8"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔷  CÓMO LLEGAR" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_gravity="center" android:textSize="15sp"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/viewPaso3SelectorTransporte"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="12dp" android:background="#F8F9FA" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚗 12 min" android:layout_marginEnd="16dp"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnSelectorAutobus"
                    android:layout_width="110dp"
                    android:layout_height="46dp"
                    app:cardBackgroundColor="#E8F0FE"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚌  Bus" android:textColor="#1A73E8" android:textStyle="bold" android:layout_gravity="center"/>
                </androidx.cardview.widget.CardView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚶 35 min" android:layout_marginLeft="16dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Línea 4 - Destino Hospital" android:textSize="16sp" android:textStyle="bold" android:textColor="#2C3E50"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Próximo autobús en 4 min desde tu parada" android:textColor="#2ECC71" android:textSize="14sp" android:layout_marginTop="4dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginVertical="16dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏱️ Duración total: 18 minutos" android:textColor="#7F8C8D" android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/viewPaso4IniciarNavegacion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@android:color/holo_blue_dark" android:layout_marginLeft="152dp" android:layout_marginTop="280dp"/>
                <View android:layout_width="8dp" android:layout_height="100dp" android:background="#2B6CB0" android:layout_marginLeft="158dp" android:layout_marginTop="180dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏁" android:textSize="24sp" android:layout_marginLeft="150dp" android:layout_marginTop="150dp"/>
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnIniciarNavegacion"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="#2ECC71"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▶️  INICIAR" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutModalExitoFinal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3000000"
            android:gravity="center"
            android:padding="24dp"
            android:elevation="10dp"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚌"
                        android:textSize="60sp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Ruta Calculada!"
                        android:textColor="#1E293B"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Excelente! Has aprendido a buscar cómo llegar al hospital en autobús. ¡Ya puedes viajar tranquilo!"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:layout_marginBottom="24dp"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnModalConcluirMision"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="#162A45"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="FINALIZAR LECCIÓN"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>