<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:id="@+id/layoutCabeceraGuia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#162A45"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layoutPasosIndicador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_centerVertical="true">

                <View
                    android:id="@+id/step1_bar"
                    android:layout_width="30dp"
                    android:layout_height="6dp"
                    android:background="#2ECC71"
                    android:layout_marginEnd="4dp" />

                <View
                    android:id="@+id/step2_bar"
                    android:layout_width="12dp"
                    android:layout_height="6dp"
                    android:background="#5C7593"
                    android:layout_marginEnd="4dp" />

                <View
                    android:id="@+id/step3_bar"
                    android:layout_width="12dp"
                    android:layout_height="6dp"
                    android:background="#5C7593"
                    android:layout_marginEnd="4dp" />

                <View
                    android:id="@+id/step4_bar"
                    android:layout_width="12dp"
                    android:layout_height="6dp"
                    android:background="#5C7593"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvPasoFraccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1/4"
                    android:textColor="#8AA1B9"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#2A405E"
                app:strokeWidth="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔊"
                    android:textSize="16sp" />
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvTextoGuiaInstruccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="PASO 1: Toca sobre el contacto de tu Tutor / Hijo para iniciar el envío."
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutBannerSeguro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F9C514"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️  Entorno seguro de pruebas — Ningún dinero real será enviado"
            android:textColor="#2C3E50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutCabeceraGuia"
        android:layout_above="@id/layoutBannerSeguro">

        <LinearLayout
            android:id="@+id/viewPaso1ListadoContactos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2C3E50"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contactos frecuentes (Bizum)"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardBackgroundColor="#E2E8F0"
                    app:strokeWidth="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JC"
                        android:layout_gravity="center"
                        android:textStyle="bold"
                        android:textColor="#64748B" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Juan Cerrajero"
                        android:textStyle="bold"
                        android:textColor="#334155"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Móvil: 611 223 344"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/itemContactoTutor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="#EBF5FF"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardBackgroundColor="#3B82F6"
                    app:strokeWidth="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TH"
                        android:layout_gravity="center"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mi Tutor / Hijo"
                        android:textStyle="bold"
                        android:textColor="#1E3A8A"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Destinatario de confianza"
                        android:textStyle="bold"
                        android:textColor="#3B82F6"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELECCIONAR"
                    android:textColor="#3B82F6"
                    android:textStyle="bold"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardBackgroundColor="#E2E8F0"
                    app:strokeWidth="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MS"
                        android:layout_gravity="center"
                        android:textStyle="bold"
                        android:textColor="#64748B" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="María Sobrina"
                        android:textStyle="bold"
                        android:textColor="#334155"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Móvil: 655 443 322"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/viewPaso2FormularioBizum"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutHeaderBizumInterno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2C3E50"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔹"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nueva Operación Bizum"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/layoutHeaderBizumInterno"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Importe a transferir"
                    android:textColor="#475569"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImporteSimulado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#3B82F6"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSimuladorImporte"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Toca aquí para indicar el dinero"
                            android:textColor="#94A3B8"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EUR (€)"
                            android:textColor="#475569"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Concepto o motivo"
                    android:textColor="#475569"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardConceptoSimulado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#CBD5E1"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSimuladorConcepto"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Escribir motivo (Ej: Regalo)"
                            android:textColor="#94A3B8"
                            android:textSize="16sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnSimuladorEnviarBizum"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#2C3E50"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="CONTINUAR CON EL ENVÍO"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/viewPaso3VerificacionSMS"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8FAFC"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verificación de Identidad"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvResumenDineroMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operación: Enviar 20€ a Mi Tutor / Hijo"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#F1F5F9"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📩 SMS de Alerta Bancaria:"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Clave para autorizar Bizum: 5544. Introduzca este código en la simulación."
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEntradaCodigoSimulado"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="10dp"
                app:strokeColor="#3B82F6"
                app:strokeWidth="2dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvSimuladorInputCodigo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Ingresar Clave"
                    android:textColor="#94A3B8"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSimuladorValidarSMS"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#27AE60"
                app:strokeWidth="0dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="CONFIRMAR OPERACIÓN"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutModalExitoFinal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3000000"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💶✨"
                        android:textSize="60sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Bizum Enviado!"
                        android:textColor="#1E293B"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Felicidades. Completaste la transferencia simulada bajo un entorno de aprendizaje seguro."
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnModalConcluirMision"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="#2C3E50"
                        app:strokeWidth="0dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="FINALIZAR LECCIÓN"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>