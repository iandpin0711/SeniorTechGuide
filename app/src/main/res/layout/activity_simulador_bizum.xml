<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerBizum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00B1A9"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬅"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvTituloSimulador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Simulador: Enviar Bizum"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/btnVolver"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerBizum"
        app:layout_constraintBottom_toTopOf="@id/bottomLayoutAsistente">

        <LinearLayout
            android:id="@+id/step1_Destinatario"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿A quién deseas enviarle dinero?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etBuscarContacto"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="Escribe el nombre o teléfono..."
                android:padding="12dp"
                android:inputType="text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contactos Recientes"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#64748B"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemContactoTutor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@android:drawable/ic_menu_myplaces"
                        android:text="👨‍🏫"
                        android:textSize="24sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mi Tutor / Hijo"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1E293B"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="600 123 456"
                            android:textSize="14sp"
                            android:textColor="#64748B"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seleccionar ➜"
                        android:textColor="#00B1A9"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step2_Importe"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Cuánto dinero vas a enviar?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"/>

            <TextView
                android:id="@+id/tvDestinatarioElegido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Destinatario: Mi Tutor / Hijo"
                android:textSize="14sp"
                android:textColor="#00B1A9"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etImporteBizum"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:gravity="center"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#00B1A9"
                android:background="@android:drawable/editbox_background"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escribe el motivo (Concepto):"
                android:textSize="16sp"
                android:textColor="#1E293B"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etConceptoBizum"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ej: Regalo, Cena, Compra..."
                android:inputType="text"
                android:padding="12dp"
                android:textSize="16sp"
                android:background="@android:drawable/editbox_background_normal"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSiguienteImporte"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:text="Continuar"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#00B1A9"
                app:cornerRadius="14dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step3_Confirmacion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 Verificación de Seguridad"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvResumenBizum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vas a enviar 20€ a Mi Tutor / Hijo en concepto de 'Prueba'."
                android:textSize="16sp"
                android:textColor="#475569"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#EFF6FF"
                app:strokeColor="#BFDBFE"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="💬 SMS SIMULADO:\nSu código de validación Bizum es: 1234"
                    android:textColor="#1E40AF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textSize="15sp"/>
            </com.google.android.material.card.MaterialCardView>

            <EditText
                android:id="@+id/etCodigoClave"
                android:layout_width="160dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:hint="xxxx"
                android:maxLength="4"
                android:inputType="number"
                android:textSize="24sp"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:background="@android:drawable/editbox_background"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinalizarBizum"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:text="Confirmar Envío de Dinero"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#2ECC71"
                app:cornerRadius="14dp"/>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomLayoutAsistente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:drawable/toast_frame"
                android:backgroundTint="#F1F5F9"
                android:padding="12dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTextoAsistente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paso 1: Pulsa sobre el contacto 'Mi Tutor / Hijo' para seleccionarlo como destinatario."
                    android:textColor="#334155"
                    android:textSize="15sp"
                    android:textStyle="normal"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="#00B1A9"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🤖"
                    android:textSize="28sp"
                    android:gravity="center"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>